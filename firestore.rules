rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL SAFETY NET
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Role Helpers (Relational lookups)
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'makkob1337@gmail.com' ||
        (isEmailVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'admin')
      );
    }
    function isRestrictedStaff() {
      return isSignedIn() && request.auth.token.email.lower() == 'makkob4ik@gmail.com';
    }
    function isManager() {
      return isSignedIn() && isEmailVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'manager';
    }
    function isMaster() {
      return isSignedIn() && isEmailVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'master';
    }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) 
        && data.keys().size() == 4
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role in ['admin', 'manager', 'master'];
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'phone', 'createdAt'])
        && data.keys().size() <= 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 20
        && (data.get('email', '') is string && data.get('email', '').size() <= 100)
        && (data.get('address', '') is string && data.get('address', '').size() <= 300);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['clientName', 'phone', 'device', 'issueDescription', 'status', 'createdAt', 'price', 'masterName'])
        && data.keys().size() <= 11
        && data.clientName is string && data.clientName.size() > 0 && data.clientName.size() <= 100
        && data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 20
        && data.device is string && data.device.size() > 0 && data.device.size() <= 200
        && data.issueDescription is string && data.issueDescription.size() <= 2000
        && data.status is string
        && data.masterName is string
        && data.price is number
        && (data.get('needsCallback', true) is bool);
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['name', 'sku', 'quantity', 'purchasePrice', 'sellPrice', 'createdAt'])
        && data.keys().size() <= 7
        && data.name is string && data.name.size() <= 200
        && data.sku is string && data.sku.size() <= 50
        && data.quantity is number && data.quantity >= 0
        && data.purchasePrice is number && data.purchasePrice >= 0
        && data.sellPrice is number && data.sellPrice >= 0;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isManager() || isRestrictedStaff());
      allow list: if isAdmin() || isManager() || isRestrictedStaff();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == 'master'; // Self-reg defaults to master
      allow update: if isAdmin() || (isSignedIn() && userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email']) && isValidUser(incoming()));
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (isAdmin() || isManager() || isMaster() || isRestrictedStaff());
      allow create: if (isSignedIn() && (isAdmin() || isManager() || isRestrictedStaff())) || (isValidClient(incoming()) && incoming().createdAt == request.time);
      allow update: if (isAdmin() || isManager() || isRestrictedStaff()) && isValidClient(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() || isRestrictedStaff();
    }

    match /orders/{orderId} {
      allow get: if true; // Allow public status check if they have the ID
      allow list: if (isSignedIn() && (isAdmin() || isManager() || isRestrictedStaff() || (isMaster() && existing().assignedMasterId == request.auth.uid)))
                  || (request.query.limit <= 5 && resource.data.phone != null);
      allow create: if (isSignedIn() && (isAdmin() || isManager() || isRestrictedStaff())) || (isValidOrder(incoming()) && incoming().createdAt == request.time);
      allow update: if (isValidOrder(incoming()) && incoming().createdAt == existing().createdAt) && (
        isAdmin() || isManager() || isMaster() || isRestrictedStaff() || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'Скасовано')
      );
      allow delete: if isAdmin() || isManager() || isRestrictedStaff() || (resource.data.status != 'Видано' && resource.data.status != 'Виконано'); // Allow personnel or users to delete if not finalized
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidInventory(incoming()) && incoming().createdAt == request.time;
      allow update: if (isAdmin() || (isMaster() && incoming().diff(existing()).affectedKeys().hasOnly(['quantity']))) && isValidInventory(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    match /orderItems/{itemId} {
      allow read: if isSignedIn() && (isAdmin() || isManager() || isMaster() || isRestrictedStaff());
      allow create: if (isAdmin() || isManager() || isMaster() || isRestrictedStaff()) && (
        exists(/databases/$(database)/documents/orders/$(incoming().orderId)) &&
        exists(/databases/$(database)/documents/inventory/$(incoming().inventoryId))
      );
    }
  }
}
